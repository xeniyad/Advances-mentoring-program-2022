{
  "AzureAdB2C": {
    "Instance": "https://mentoringecommerce.b2clogin.com/",
    "ClientId": "67ae9f3a-342e-4554-84bc-0e7ffe5e5b85",
    "Domain": "mentoringecommerce.onmicrosoft.com",
    "SignUpSignInPolicyId": "B2C_1_signupsignin1"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/catalog" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/cart/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://catalog-service"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart": {
            "Address": "http://cart-service"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders": {
            "Address": "http://order-service"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "https://cart-service.internal.lemonstone-6c6612db.uaenorth.azurecontainerapps.io,https://catalog-service.internal.lemonstone-6c6612db.uaenorth.azurecontainerapps.io,https://order-service.internal.lemonstone-6c6612db.uaenorth.azurecontainerapps.io,https://calm-pond-0fdf51900.7.azurestaticapps.net"
}
