{
  "AzureAdB2C": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "32486baf-e4f4-4937-85bd-622bd4a709b7",
    "TenantId": "cc0890f9-759c-4f92-b85c-a632a36232bf",
    "Domain": "advmentoring.onmicrosoft.com"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/catalog" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/cart/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://catalog-service"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart": {
            "Address": "http://cart-service"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders": {
            "Address": "http://order-service"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
