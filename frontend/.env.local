# Mock Azure AD auth for local development.
# The predefined user is "admin@local.dev" (see src/auth/MockMsalProvider.jsx).
# Login/logout work normally but no real Azure AD call is made.
VITE_AUTH_MOCK=true

# Uncomment and set if running frontend without AppHost (AppHost sets this automatically).
# VITE_API_URL=http://localhost:5000
